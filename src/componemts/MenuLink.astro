---
//TypeScript
interface Props{
    preTitle: string;
    title: string;
    href?: string;
}
const { preTitle, title, href="#" } = Astro.props;

const isActive = Astro.url.pathname.startsWith(href);
console.log(Astro.url.pathname)
---
<li class={ isActive ? "active" : "" }>
    <a href={href}>
        <span>{preTitle}</span>
        <span>{title}</span>
    </a>
    <div class="dot"></div>
</li>
<style>
    li{
        position: relative;
        border-bottom: 3px solid transparent;
    }
    li.active{
        border-bottom: 3px solid #000;
    }
    a{
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 0px 10px ;
        text-decoration: none;
        color: black;
        
    }
    a span:first-child{
        font-weight: 300;

    }
    a span:last-child{
        font-weight: bold;
    }
    .dot{
        width: 3px;
        height: 3px;
        background-color: red;
        border-radius: 100%;
        position: absolute;
        right: -5px;
        top: -5px;
    }
</style>